const { Sparky, isPublic } = require("../lib");
const { GoogleGenerativeAI } = require("@google/generative-ai");
const fs = require("fs");

const GEMINI_API_KEY = "AQ.Ab8RN6JUGNSE8Mh5JDMBDVjKjePISZwx2K1qv0g5WvurAsbTuA";
const genAI = new GoogleGenerativeAI(GEMINI_API_KEY);

// ෆයිල් එකක් (Image) base64 format එකට හරවන පොඩි Function එකක්
function fileToGenerativePart(path, mimeType) {
    return {
        inlineData: {
            data: Buffer.from(fs.readFileSync(path)).toString("base64"),
            mimeType
        },
    };
}

Sparky({
    name: "aiimg",
    alias: ["describe", "imageai"],
    fromMe: isPublic,
    category: "ai",
    desc: "Analyze an image using Gemini AI"
}, async ({ client, m }) => {
    
    // 1. යූසර් එවපු මැසේජ් එකේ ෆොටෝ එකක් තියෙනවද බලනවා
    let quoted = m.quoted ? m.quoted : m;
    let mime = (quoted.msg || quoted).mimetype || "";
    if (!/image/.test(mime)) {
        return m.reply("❌ *කරුණාකර ෆොටෝ එකක් එවලා ඒකට Reply කරලා .aiimg කියලා ගහන්න.*");
    }

    try {
        await m.react("⏳");
        
        // 2. ෆොටෝ එක ඩවුන්ලෝඩ් කරගන්නවා
        let media = await client.downloadAndSaveMediaMessage(quoted);
        
        // 3. Gemini AI එකට ෆොටෝ එකයි, ප්‍රශ්නෙයි යවනවා
        const model = genAI.getGenerativeModel({ model: "gemini-1.5-flash" });
        const prompt = "Please analyze this image and explain what is in it in detail (in Sinhala if possible).";

        const imagePart = fileToGenerativePart(media, mime);
        const result = await model.generateContent([prompt, imagePart]);
        const response = result.response.text();

        // 4. විස්තරේ යවනවා
        await m.reply(`🧠 *AI Image Analysis:*\n\n${response}`);
        await m.react("✅");

        // 5. වැඩේ ඉවර වුණාම ෆයිල් එක ඩිලීට් කරනවා
        fs.unlinkSync(media);

    } catch (error) {
        console.error("AI Image Error:", error);
        m.reply("❌ *පින්තූරය විස්තර කිරීමේදී දෝෂයක් ඇති විය.*");
        await m.react("❌");
    }
});
